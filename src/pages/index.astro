---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import AiVendorBar from '../components/AiVendorBar.astro';
import StatsStrip from '../components/StatsStrip.astro';
// import LogoSlider from '../components/LogoSlider.astro';  // hidden until real client logos are available
import Problem from '../components/Problem.astro';
import OfferCards from '../components/OfferCards.astro';
import SuccessStories from '../components/SuccessStories.astro';
import UseCaseCatalog from '../components/UseCaseCatalog.astro';
import About from '../components/About.astro';
import Trust from '../components/Trust.astro';
import Faq from '../components/Faq.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';

const description =
  'KI-Beratung für Schweizer KMU: Prozess-Screening, Pilot-Umsetzung, Betrieb. Transparente Fixpreise, 10+ gelieferte Projekte, ein Ansprechpartner mit ETH-Hintergrund. Integriert Claude, ChatGPT, Mistral und Swiss-hosted AlpineAI.';
---

<BaseLayout
  title="KI-Beratung für Schweizer KMU — ki-kmu-schweiz.ch"
  description={description}
>
  <Header />
  <main id="top">
    <Hero />
    <AiVendorBar />
    <StatsStrip />
    {/* <LogoSlider /> hidden until real client logos are available */}
    <Problem />
    <OfferCards />
    <SuccessStories />
    <UseCaseCatalog />
    <About />
    <Trust />
    <Faq />
    <Contact />
  </main>
  <Footer />
  <WhatsAppFloat />
</BaseLayout>
