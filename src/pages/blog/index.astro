---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFormatter = new Intl.DateTimeFormat('de-CH', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title="Blog — Praktische KI für Schweizer KMU"
  description="Tiefe, ehrliche Artikel zu KI-Strategie, Datenschutz und Tool-Auswahl für Schweizer KMU. Ohne Buzzwords, mit konkreten Zahlen und Anwendungsbeispielen."
>
  <Header />
  <main id="top">
    <section class="py-section md:py-section-lg">
      <div class="container-page">
        <div class="max-w-[840px] mb-14">
          <p class="label-tag text-accent-dark mb-5">Blog</p>
          <h1 class="text-display text-ink-primary">
            Praktische KI für <span class="mark-accent">Schweizer KMU</span>.
          </h1>
          <p class="mt-6 text-lg md:text-xl leading-relaxed text-ink-secondary">
            Tiefe, ehrliche Artikel zu Strategie, Datenschutz und Tool-Auswahl —
            aus der Praxis von KI-Projekten mit 10+ Schweizer KMU. Ohne Buzzwords,
            mit konkreten Zahlen und branchenspezifischen Beispielen.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            posts.map((post) => (
              <a
                href={`/blog/${post.slug}/`}
                class="card-hoverable p-7 flex flex-col group"
              >
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="label-tag text-[10px] bg-ink-primary text-accent px-2 py-1 rounded">
                      {tag}
                    </span>
                  ))}
                </div>
                <h2 class="text-xl md:text-2xl font-extrabold text-ink-primary mb-3 leading-tight tracking-tight group-hover:text-accent-dark transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-sm text-ink-secondary leading-relaxed grow mb-5">
                  {post.data.description}
                </p>
                <div class="flex items-center justify-between pt-4 border-t-2 border-ink-primary text-xs text-ink-muted font-medium">
                  <span>{dateFormatter.format(post.data.pubDate)}</span>
                  <span>{post.data.readTime}</span>
                </div>
                <span class="mt-5 text-sm font-extrabold text-ink-primary group-hover:underline">
                  Artikel lesen →
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
