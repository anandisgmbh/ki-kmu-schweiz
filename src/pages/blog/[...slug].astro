---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const dateFormatter = new Intl.DateTimeFormat('de-CH', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

// JSON-LD Article schema
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updated ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author,
    url: 'https://ki-kmu-schweiz.ch/#ueber-mich',
  },
  publisher: {
    '@type': 'Organization',
    name: 'KI-KMU-Schweiz GmbH',
    url: 'https://ki-kmu-schweiz.ch',
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://ki-kmu-schweiz.ch/blog/${post.slug}/`,
  },
  keywords: post.data.tags.join(', '),
  inLanguage: 'de-CH',
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={`https://ki-kmu-schweiz.ch/blog/${post.slug}/`}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
    slot="head"
  />
  <Header />
  <main id="top">
    <article class="py-section">
      <div class="container-page">
        <div class="max-w-[780px] mb-12">
          <a
            href="/blog/"
            class="label-tag text-accent-dark hover:text-accent inline-flex items-center gap-2 mb-6"
          >
            ← Alle Artikel
          </a>

          <div class="flex flex-wrap gap-2 mb-6">
            {
              post.data.tags.map((tag) => (
                <span class="label-tag text-[10px] bg-ink-primary text-accent px-2.5 py-1 rounded">
                  {tag}
                </span>
              ))
            }
          </div>

          <h1 class="text-display text-ink-primary mb-6">
            {post.data.title}
          </h1>

          <p class="text-lg md:text-xl leading-relaxed text-ink-secondary mb-8">
            {post.data.description}
          </p>

          <div class="flex items-center gap-4 pt-6 border-t-2 border-ink-primary text-sm text-ink-muted font-medium">
            <span class="font-semibold text-ink-primary">{post.data.author}</span>
            <span>·</span>
            <span>{dateFormatter.format(post.data.pubDate)}</span>
            <span>·</span>
            <span>{post.data.readTime}</span>
          </div>
        </div>

        <div class="prose-custom max-w-[780px]">
          <Content />
        </div>

        <div class="max-w-[780px] mt-16 pt-10 border-t-2 border-ink-primary">
          <div class="bg-ink-primary text-ink-inverted p-8 md:p-10 rounded-card border-2 border-ink-primary">
            <p class="label-tag text-accent mb-4">Erstgespräch</p>
            <h2 class="text-2xl md:text-3xl font-extrabold leading-tight tracking-tight mb-5 text-ink-inverted">
              Bereit, die Theorie in einem Projekt zu prüfen?
            </h2>
            <p class="text-white/75 leading-relaxed mb-6 max-w-[560px]">
              Dreissig Minuten, konkret, kostenlos. Wir schauen gemeinsam,
              wo in Ihrem Betrieb der grösste Hebel liegt — und wie ein
              realistischer Pilot aussehen könnte.
            </p>
            <a href="/#kontakt" class="btn-primary text-sm">
              Erstgespräch vereinbaren →
            </a>
          </div>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .prose-custom {
    font-size: 17px;
    line-height: 1.7;
    color: #3f4756;
  }
  .prose-custom > * + * {
    margin-top: 1.25em;
  }
  .prose-custom h2 {
    font-size: clamp(1.625rem, 1.4vw + 1rem, 2.125rem);
    font-weight: 800;
    color: #0B0F1A;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-top: 2.5em;
    margin-bottom: 0.8em;
  }
  .prose-custom h3 {
    font-size: clamp(1.25rem, 0.8vw + 1rem, 1.5rem);
    font-weight: 800;
    color: #0B0F1A;
    letter-spacing: -0.01em;
    line-height: 1.3;
    margin-top: 2em;
    margin-bottom: 0.5em;
  }
  .prose-custom p {
    margin-bottom: 1.1em;
  }
  .prose-custom strong {
    color: #0B0F1A;
    font-weight: 700;
  }
  .prose-custom a {
    color: #7FAE00;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    font-weight: 600;
  }
  .prose-custom a:hover {
    color: #0B0F1A;
    background: #C9FF00;
  }
  .prose-custom ul, .prose-custom ol {
    margin: 1.1em 0;
    padding-left: 1.5em;
  }
  .prose-custom li {
    margin: 0.4em 0;
  }
  .prose-custom ul li {
    list-style: disc;
  }
  .prose-custom ol li {
    list-style: decimal;
  }
  .prose-custom blockquote {
    border-left: 4px solid #0B0F1A;
    padding: 1em 1.5em;
    margin: 1.5em 0;
    background: #F4FFD4;
    font-style: normal;
  }
  .prose-custom blockquote p:last-child {
    margin-bottom: 0;
  }
  .prose-custom code {
    background: #f5f5f5;
    padding: 0.15em 0.35em;
    border-radius: 4px;
    font-size: 0.92em;
    font-family: 'SF Mono', Monaco, monospace;
  }
  .prose-custom table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5em 0;
    border: 2px solid #0B0F1A;
    border-radius: 8px;
    overflow: hidden;
  }
  .prose-custom th,
  .prose-custom td {
    padding: 0.7em 1em;
    text-align: left;
    border-bottom: 1px solid #e6e8ec;
    font-size: 0.95em;
  }
  .prose-custom thead {
    background: #0B0F1A;
    color: #fff;
  }
  .prose-custom th {
    font-weight: 700;
  }
  .prose-custom tr:last-child td {
    border-bottom: none;
  }
  .prose-custom hr {
    border: none;
    border-top: 2px solid #e6e8ec;
    margin: 2.5em 0;
  }
</style>
