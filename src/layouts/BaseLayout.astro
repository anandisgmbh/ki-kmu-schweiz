          '@type': 'Offer',
          name: 'Partnerschaft & Betrieb',
          price: '2500',
          priceCurrency: 'CHF',
          priceSpecification: { '@type': 'UnitPriceSpecification', price: '2500', priceCurrency: 'CHF', unitCode: 'MON' },
