---
const vendors = [
  { name: 'Claude', provider: 'Anthropic', logo: '/logos/ai/claude.svg', swiss: false },
  { name: 'ChatGPT', provider: 'OpenAI', logo: '/logos/ai/openai.svg', swiss: false },
  { name: 'Gemini', provider: 'Google', logo: '/logos/ai/google.svg', swiss: false },
  { name: 'Mistral', provider: 'Mistral AI (EU)', logo: '/logos/ai/mistral.svg', swiss: false },
  { name: 'Llama', provider: 'Meta (Open Source)', logo: '/logos/ai/meta.svg', swiss: false },
  { name: 'AlpineAI', provider: '🇨🇭 Swiss-hosted', logo: null, swiss: true },
];
---

<section aria-label="KI-Modelle, die wir integrieren" class="py-10 md:py-14 bg-bg-primary border-t-2 border-b-2 border-ink-primary">
  <div class="container-page">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-8">
      <p class="label-tag text-ink-primary max-w-[520px]">
        Wir bauen mit den besten KI-Modellen. Gehostet dort, wo <span class="mark-accent">Ihre Daten hingehören</span>.
      </p>
      <p class="text-sm text-ink-muted max-w-[360px]">
        Sie wählen die Technologie — oder wir empfehlen sie. Immer mit Blick auf nDSG, Kosten und Performance.
      </p>
    </div>

    <ul class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-0 border-2 border-ink-primary rounded-card overflow-hidden">
      {
        vendors.map((v, i) => (
          <li
            class:list={[
              'relative px-5 py-6 flex flex-col items-center justify-center text-center min-h-[156px]',
              i < vendors.length - 1 && 'border-b-2 sm:border-b-2 lg:border-b-0 sm:border-r-2 lg:border-r-2 border-ink-primary',
              v.swiss && 'bg-accent',
            ]}
          >
            {v.swiss && (
              <span class="absolute top-2 right-2 text-[9px] font-black uppercase tracking-wider bg-ink-primary text-accent px-1.5 py-0.5 rounded">
                Swiss
              </span>
            )}

            <div class="h-10 flex items-center justify-center mb-3">
              {v.logo ? (
                <img
                  src={v.logo}
                  alt=""
                  width="40"
                  height="40"
                  class="h-10 w-auto"
                  loading="lazy"
                  aria-hidden="true"
                />
              ) : (
                <svg width="40" height="40" viewBox="0 0 40 40" aria-hidden="true">
                  <path d="M 4 30 L 12 14 L 17 22 L 22 10 L 28 24 L 36 30 Z" fill="#0B0F1A" />
                </svg>
              )}
            </div>

            <p class={`text-xl md:text-2xl font-extrabold tracking-tight leading-none ${v.swiss ? 'text-ink-primary' : 'text-ink-primary'}`}>
              {v.name}
            </p>
            <p class={`mt-1.5 text-[11px] font-medium leading-tight ${v.swiss ? 'text-ink-primary/70' : 'text-ink-muted'}`}>
              {v.provider}
            </p>
          </li>
        ))
      }
    </ul>

    <p class="mt-6 text-sm text-ink-secondary max-w-[680px]">
      <strong class="text-ink-primary">AlpineAI</strong> ist unsere Empfehlung, wenn maximaler Datenschutz zählt:
      Swiss-hosted, nDSG-konform, FINMA-tauglich. Für Treuhand, Anwalt, Gesundheit und sensible Branchen
      die erste Wahl — ohne Abstriche beim Modell.
    </p>
  </div>
</section>
