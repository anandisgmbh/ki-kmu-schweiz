---
import { getCollection } from 'astro:content';

const faqs = (await getCollection('faqs')).sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  faqs.map(async (f) => {
    const { Content } = await f.render();
    return { id: f.id, question: f.data.question, Content };
  })
);
---

<section id="faq" class="py-section md:py-section-lg bg-bg-primary border-t-2 border-ink-primary">
  <div class="container-page">
    <div class="max-w-[840px] mb-12">
      <p class="label-tag text-accent-dark mb-5">FAQ</p>
      <h2 class="text-display text-ink-primary">
        Was Inhaber vor dem <span class="mark-accent">Erstgespräch</span> wissen wollen.
      </h2>
      <p class="mt-6 text-lg md:text-xl leading-relaxed text-ink-secondary">
        Die Fragen, die am häufigsten im ersten Gespräch aufkommen. Wenn Ihre
        Frage nicht dabei ist — schreiben Sie mir direkt auf WhatsApp oder per Mail.
      </p>
    </div>

    <div class="max-w-[860px] space-y-3">
      {
        rendered.map((f) => (
          <details class="faq-item group border-2 border-ink-primary rounded-card overflow-hidden bg-bg-card">
            <summary class="list-none cursor-pointer p-6 md:p-7 flex items-start justify-between gap-5 hover:bg-bg-accent transition-colors">
              <h3 class="text-lg md:text-xl font-extrabold text-ink-primary leading-snug tracking-tight">
                {f.question}
              </h3>
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                class="text-ink-primary shrink-0 mt-1 transition-transform group-open:rotate-180"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </summary>
            <div class="px-6 pb-7 md:px-7 text-ink-secondary leading-relaxed border-t border-border">
              <div class="pt-5">
                <f.Content />
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
</style>
