---
const stats = [
  { value: '10+', label: 'Projekte geliefert', sub: 'In Schweizer KMU' },
  { value: '8', label: 'Wochen bis Live', sub: 'Vom Kick-off zur Lösung' },
  { value: "CHF 2'500", label: 'Einstieg fix', sub: 'Keine versteckten Kosten' },
  { value: '100 %', label: 'CH-Datenhaltung', sub: 'Auf Wunsch On-Prem' },
];
---

<section class="section-dark py-14 md:py-20 border-t-2 border-b-2 border-ink-primary">
  <div class="container-page">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
      {
        stats.map((s) => (
          <div>
            <p class="text-stat text-accent tabular-nums">{s.value}</p>
            <p class="mt-3 text-lg md:text-xl font-extrabold text-ink-inverted leading-tight">
              {s.label}
            </p>
            <p class="mt-1 text-sm text-white/60">{s.sub}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
