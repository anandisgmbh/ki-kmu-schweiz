---
const stats = [
  { prefix: '', value: '10+', label: 'Projekte geliefert', sub: 'In Schweizer KMU' },
  { prefix: '', value: '8', label: 'Wochen bis Live', sub: 'Vom Kick-off zur Lösung' },
  { prefix: 'CHF', value: "2'500", label: 'Einstieg fix', sub: 'Keine versteckten Kosten' },
  { prefix: '', value: '100 %', label: 'CH-Datenhaltung', sub: 'Auf Wunsch On-Prem' },
];
---

<section class="section-dark py-14 md:py-20 border-t-2 border-b-2 border-ink-primary">
  <div class="container-page">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
      {
        stats.map((s) => (
          <div class="text-center">
            <div class="flex items-start justify-center gap-1.5 text-accent leading-none">
              {s.prefix && (
                <span class="text-xs md:text-sm font-extrabold tracking-wider pt-[0.6em] uppercase">
                  {s.prefix}
                </span>
              )}
              <span class="text-stat tabular-nums whitespace-nowrap">{s.value}</span>
            </div>
            <p class="mt-3 text-lg md:text-xl font-extrabold text-ink-inverted leading-tight">
              {s.label}
            </p>
            <p class="mt-1 text-sm text-white/60">{s.sub}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
