---
import { getCollection } from 'astro:content';

const anchors = (await getCollection('cases'))
  .filter((c) => c.data.anchor)
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="stories" class="py-16 md:py-section-lg bg-bg-primary">
  <div class="container-page">
    <div class="max-w-[1040px] mb-14">
      <p class="label-tag text-accent-dark mb-5">Success Stories</p>
      <h2 class="text-display text-ink-primary">
        Vier Projekte. Vier Branchen.
        <br /><span class="mark-accent">Messbare Ergebnisse</span>.
      </h2>
      <p class="mt-6 text-lg md:text-xl leading-relaxed text-ink-secondary">
        Jede dieser Geschichten ist ein echter Betrieb, den ich begleitet habe.
        Die Zahlen sind echt, die Use-Cases laufen in Produktion, und die
        Kunden können bei ernsthaftem Interesse als Referenz kontaktiert werden.
      </p>
    </div>

    <div class="space-y-6">
      {
        anchors.map((c, i) => (
          <article class="card p-8 md:p-10 grid md:grid-cols-[1fr_auto] gap-8 md:gap-12 items-start">
            <div>
              <div class="flex flex-wrap items-center gap-3 mb-5">
                <span class="label-num">{String(i + 1).padStart(2, '0')}</span>
                <span class="label-tag bg-ink-primary text-accent px-3 py-1.5 rounded-full">
                  {c.data.industryLabel}
                </span>
                <span class="label-tag text-ink-muted">{c.data.useCaseLabel}</span>
                <span class="label-tag text-ink-muted">{c.data.size} · {c.data.region}</span>
              </div>

              <h3 class="text-3xl md:text-4xl font-extrabold text-ink-primary mb-5 tracking-tight leading-tight">
                {c.data.title}
              </h3>

              <div class="space-y-3 text-ink-secondary leading-relaxed max-w-[620px]">
                <p>
                  <strong class="text-ink-primary">Ausgangslage.</strong> {c.data.pain}
                </p>
                <p>
                  <strong class="text-ink-primary">Lösung.</strong> {c.data.solution}
                </p>
              </div>

              <p class="mt-5 text-xs font-bold text-ink-muted uppercase tracking-wider">
                Umsetzung: {c.data.duration}
              </p>
            </div>

            <div class="md:min-w-[260px] md:border-l-2 md:border-ink-primary md:pl-8">
              <p class="label-tag text-accent-dark mb-4">Ergebnis</p>
              <ul class="space-y-4">
                {
                  c.data.metrics.map((m) => (
                    <li class="flex items-start gap-3">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3.5"
                        class="text-accent-dark shrink-0 mt-1"
                        aria-hidden="true"
                      >
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      <span class="text-lg font-extrabold text-ink-primary leading-snug tracking-tight">
                        {m}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </article>
        ))
      }
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-between gap-4 p-6 md:p-8 rounded-card bg-ink-primary text-ink-inverted">
      <div>
        <p class="label-tag text-accent mb-2">Mehr Referenzen</p>
        <p class="text-lg md:text-xl font-extrabold tracking-tight">
          Bei ernsthaftem Interesse an Detail-Referenzen — gerne im Erstgespräch.
        </p>
      </div>
      <a href="#kontakt" class="btn-primary text-sm">
        Erstgespräch anfragen →
      </a>
    </div>
  </div>
</section>
