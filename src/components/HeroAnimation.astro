---
---

<div class="hero-anim" aria-hidden="true">
  <svg
    viewBox="0 0 320 660"
    class="w-full h-auto max-w-[260px]"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <pattern id="bg-dots" x="0" y="0" width="24" height="24" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1" fill="#0B0F1A" opacity="0.12" />
      </pattern>
    </defs>

    <!-- Background: dot grid -->
    <rect x="0" y="0" width="320" height="660" fill="url(#bg-dots)" />

    <!-- Background: Swiss alpine silhouette -->
    <path
      d="M 0 580 L 24 550 L 48 568 L 72 532 L 96 558 L 120 518 L 144 550 L 168 506 L 192 542 L 216 512 L 240 538 L 264 500 L 288 532 L 320 512 L 320 660 L 0 660 Z"
      fill="#0B0F1A"
      opacity="0.06"
    />

    <!-- Swiss cross badge (top-right) -->
    <g class="swiss-cross">
      <rect x="270" y="12" width="38" height="38" rx="5" fill="#DC0018" stroke="#0B0F1A" stroke-width="3" />
      <rect x="278" y="28" width="22" height="6" fill="#ffffff" />
      <rect x="286" y="20" width="6" height="22" fill="#ffffff" />
    </g>

    <!-- TOP: Input node -->
    <g class="node node-input">
      <rect x="56" y="18" width="200" height="52" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="156" y="40" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        INPUT
      </text>
      <text x="156" y="60" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="800" fill="#0B0F1A">
        Ihr Prozess
      </text>
    </g>

    <!-- Line 1: Input → Center -->
    <line x1="160" y1="70" x2="160" y2="112" stroke="#0B0F1A" stroke-width="2.5" stroke-dasharray="8 6" class="flow flow-1" />

    <!-- "8 Wochen" speed badge -->
    <g class="speed-badge">
      <rect x="196" y="80" width="100" height="22" rx="11" fill="#0B0F1A" stroke="#0B0F1A" stroke-width="2.5" />
      <text x="246" y="95" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" font-weight="900" fill="#C9FF00" letter-spacing="0.6">
        ⚡ 8 WOCHEN
      </text>
    </g>

    <!-- CENTER: KI-Agent with model badges (enlarged) -->
    <g class="node node-center">
      <rect x="16" y="112" width="288" height="274" rx="16" fill="#C9FF00" stroke="#0B0F1A" stroke-width="3" class="ki-core" />

      <text x="160" y="140" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="900" fill="#0B0F1A" letter-spacing="1.8">
        KI-AGENT
      </text>
      <text x="160" y="172" text-anchor="middle" font-family="Inter, sans-serif" font-size="20" font-weight="800" fill="#0B0F1A">
        Analyse · Bau · Betrieb
      </text>

      <!--
        Model badges — 5 AI providers.
        Brand logos live in /public/logos/ai/ and are referenced via <image href>.
        AlpineAI still uses an inline mountain icon (no official asset yet).
      -->

      <!-- Badge 1: Claude -->
      <g transform="translate(40, 192)">
        <rect x="0" y="0" width="240" height="28" rx="7" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
        <image href="/logos/ai/claude.svg" x="12" y="5" width="18" height="18" preserveAspectRatio="xMidYMid meet" />
        <text x="132" y="19" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="800" fill="#0B0F1A">
          Claude<tspan dx="5" font-size="11" font-weight="500" fill="#6b7382">Anthropic</tspan>
        </text>
      </g>

      <!-- Badge 2: GPT -->
      <g transform="translate(40, 226)">
        <rect x="0" y="0" width="240" height="28" rx="7" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
        <image href="/logos/ai/openai.svg" x="12" y="5" width="18" height="18" preserveAspectRatio="xMidYMid meet" />
        <text x="132" y="19" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="800" fill="#0B0F1A">
          GPT<tspan dx="5" font-size="11" font-weight="500" fill="#6b7382">OpenAI</tspan>
        </text>
      </g>

      <!-- Badge 3: Gemini -->
      <g transform="translate(40, 260)">
        <rect x="0" y="0" width="240" height="28" rx="7" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
        <image href="/logos/ai/google.svg" x="12" y="5" width="18" height="18" preserveAspectRatio="xMidYMid meet" />
        <text x="132" y="19" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="800" fill="#0B0F1A">
          Gemini<tspan dx="5" font-size="11" font-weight="500" fill="#6b7382">Google</tspan>
        </text>
      </g>

      <!-- Badge 4: Mistral -->
      <g transform="translate(40, 294)">
        <rect x="0" y="0" width="240" height="28" rx="7" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
        <image href="/logos/ai/mistral.svg" x="12" y="5" width="18" height="18" preserveAspectRatio="xMidYMid meet" />
        <text x="132" y="19" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="800" fill="#0B0F1A">
          Mistral<tspan dx="5" font-size="11" font-weight="500" fill="#6b7382">Mistral AI</tspan>
        </text>
      </g>

      <!-- Badge 5: AlpineAI — mountain peaks (highlighted) -->
      <g transform="translate(28, 336)">
        <rect x="0" y="0" width="264" height="36" rx="8" fill="#0B0F1A" stroke="#0B0F1A" stroke-width="2.5" />
        <g transform="translate(24, 18)">
          <path d="M -12 7 L -5 -5 L -1 2 L 3 -8 L 12 7 Z" fill="#C9FF00" />
        </g>
        <text x="150" y="23" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="800" fill="#C9FF00">
          AlpineAI · 🇨🇭 Swiss-hosted
        </text>
      </g>
    </g>

    <!-- Line 2: Center → Results -->
    <line x1="160" y1="386" x2="160" y2="428" stroke="#0B0F1A" stroke-width="2.5" stroke-dasharray="8 6" class="flow flow-2" />

    <!-- Result 1: Zeit -->
    <g class="node node-output out-1">
      <rect x="16" y="428" width="288" height="52" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="34" y="450" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS 01
      </text>
      <text x="34" y="470" font-family="Inter, sans-serif" font-size="17" font-weight="800" fill="#0B0F1A">
        58 % Zeitersparnis
      </text>
      <g transform="translate(276, 454)">
        <circle r="15" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="result-dot" />
        <path d="M -5 -3 L 0 5 L 5 -3" fill="none" stroke="#0B0F1A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
      </g>
    </g>

    <!-- Result 2: Aufträge -->
    <g class="node node-output out-2">
      <rect x="16" y="492" width="288" height="52" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="34" y="514" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS 02
      </text>
      <text x="34" y="534" font-family="Inter, sans-serif" font-size="17" font-weight="800" fill="#0B0F1A">
        +28 % mehr Aufträge
      </text>
      <g transform="translate(276, 518)">
        <circle r="15" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="result-dot" />
        <path d="M -5 3 L 0 -5 L 5 3" fill="none" stroke="#0B0F1A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
      </g>
    </g>

    <!-- Result 3: 24/7 -->
    <g class="node node-output out-3">
      <rect x="16" y="556" width="288" height="52" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="34" y="578" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS 03
      </text>
      <text x="34" y="598" font-family="Inter, sans-serif" font-size="17" font-weight="800" fill="#0B0F1A">
        24/7 Erreichbarkeit
      </text>
      <g transform="translate(276, 582)">
        <circle r="15" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="result-dot" />
        <path d="M -5 0 L -1 4 L 5 -4" fill="none" stroke="#0B0F1A" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
      </g>
    </g>

    <!-- Data packets flowing along pipeline -->
    <circle r="7" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2.5">
      <animateMotion dur="1.6s" repeatCount="indefinite" path="M 160 70 L 160 112" />
    </circle>
    <circle r="7" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2.5">
      <animateMotion dur="1.6s" repeatCount="indefinite" begin="0.6s" path="M 160 386 L 160 428" />
    </circle>

    <!-- Bottom: LIVE indicator + Swiss Hosted signature -->
    <g>
      <circle cx="22" cy="634" r="5" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="live-dot" />
      <text x="34" y="638" font-family="Inter, sans-serif" font-size="10" font-weight="900" fill="#0B0F1A" letter-spacing="1">LIVE</text>
    </g>
    <g>
      <text x="70" y="638" font-family="Inter, sans-serif" font-size="10" font-weight="700" fill="#6b7382">
        <tspan class="status-line status-1">Prozess analysiert ✓</tspan>
      </text>
      <text x="70" y="638" font-family="Inter, sans-serif" font-size="10" font-weight="700" fill="#6b7382" opacity="0">
        <tspan class="status-line status-2">Lösung gebaut ✓</tspan>
      </text>
      <text x="70" y="638" font-family="Inter, sans-serif" font-size="10" font-weight="700" fill="#6b7382" opacity="0">
        <tspan class="status-line status-3">CH-Cloud deployed ✓</tspan>
      </text>
    </g>
    <g>
      <!-- Swiss signature right-bottom -->
      <rect x="210" y="626" width="10" height="10" fill="#DC0018" />
      <rect x="212" y="630" width="6" height="2" fill="#ffffff" />
      <rect x="214" y="628" width="2" height="6" fill="#ffffff" />
      <text x="224" y="635" font-family="Inter, sans-serif" font-size="10" font-weight="900" fill="#0B0F1A" letter-spacing="0.4">
        HOSTED IN CH
      </text>
    </g>
  </svg>
</div>

<style>
  .hero-anim {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .flow {
    animation: dash-flow 1.4s linear infinite;
  }
  .flow-1 { animation-delay: 0s; }
  .flow-2 { animation-delay: 0.5s; }

  @keyframes dash-flow {
    to { stroke-dashoffset: -28; }
  }

  .ki-core {
    animation: ki-pulse 3s ease-in-out infinite;
  }

  @keyframes ki-pulse {
    0%, 100% {
      filter: drop-shadow(0 0 0px rgba(201, 255, 0, 0.5));
    }
    50% {
      filter: drop-shadow(0 0 14px rgba(201, 255, 0, 0.85));
    }
  }

  .node-output rect {
    animation: out-nudge 4s ease-in-out infinite;
  }
  .out-1 rect { animation-delay: 0.0s; }
  .out-2 rect { animation-delay: 0.5s; }
  .out-3 rect { animation-delay: 1.0s; }

  @keyframes out-nudge {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(2px); }
  }

  .result-dot {
    animation: result-pulse 3.5s ease-in-out infinite;
  }
  .out-1 .result-dot { animation-delay: 0s; }
  .out-2 .result-dot { animation-delay: 0.7s; }
  .out-3 .result-dot { animation-delay: 1.4s; }

  @keyframes result-pulse {
    0%, 100% {
      opacity: 0.75;
    }
    50% {
      opacity: 1;
      filter: drop-shadow(0 0 8px rgba(201, 255, 0, 0.9));
    }
  }

  .speed-badge {
    animation: speed-pulse 2.4s ease-in-out infinite;
    transform-origin: 246px 91px;
  }
  @keyframes speed-pulse {
    0%, 100% { opacity: 0.9; }
    50% { opacity: 1; }
  }

  .swiss-cross {
    animation: swiss-breathe 3s ease-in-out infinite;
    transform-origin: 289px 31px;
  }
  @keyframes swiss-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.04); }
  }

  .live-dot {
    animation: live-pulse 1.2s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .status-line {
    animation: status-cycle 4.5s ease-in-out infinite;
    opacity: 0;
  }
  .status-1 { animation-delay: 0s; }
  .status-2 { animation-delay: 1.5s; }
  .status-3 { animation-delay: 3.0s; }

  @keyframes status-cycle {
    0%, 22% { opacity: 0; }
    5%, 20% { opacity: 1; }
    30%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow, .ki-core, .node-output rect, .result-dot, .speed-badge, .swiss-cross, .live-dot, .status-line {
      animation: none;
    }
  }
</style>
