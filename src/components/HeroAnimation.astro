---
---

<div class="hero-anim" aria-hidden="true">
  <svg
    viewBox="0 0 320 560"
    class="w-full h-auto max-w-[300px]"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <pattern id="bg-dots" x="0" y="0" width="26" height="26" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1" fill="#0B0F1A" opacity="0.12" />
      </pattern>
    </defs>

    <rect x="0" y="0" width="320" height="560" fill="url(#bg-dots)" />

    <!-- Top: Input node -->
    <g class="node node-input">
      <rect x="60" y="14" width="200" height="52" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="160" y="36" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        INPUT
      </text>
      <text x="160" y="56" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="800" fill="#0B0F1A">
        Ihr Prozess
      </text>
    </g>

    <!-- Line 1: Input → Center -->
    <line x1="160" y1="66" x2="160" y2="104" stroke="#0B0F1A" stroke-width="2.5" stroke-dasharray="8 6" class="flow flow-1" />

    <!-- Center: KI-Agent with vertically stacked model badges -->
    <g class="node node-center">
      <rect x="20" y="104" width="280" height="200" rx="16" fill="#C9FF00" stroke="#0B0F1A" stroke-width="3" class="ki-core" />

      <text x="160" y="126" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#0B0F1A" letter-spacing="1.5">
        KI-AGENT
      </text>
      <text x="160" y="150" text-anchor="middle" font-family="Inter, sans-serif" font-size="17" font-weight="800" fill="#0B0F1A">
        Analyse · Bau · Betrieb
      </text>

      <!-- Vertically stacked model badges -->
      <g transform="translate(90, 172)">
        <!-- claude -->
        <g>
          <rect x="0" y="0" width="140" height="24" rx="6" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
          <text x="70" y="16" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="800" fill="#0B0F1A">claude</text>
        </g>
        <!-- GPT -->
        <g transform="translate(0, 30)">
          <rect x="0" y="0" width="140" height="24" rx="6" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
          <text x="70" y="16" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="800" fill="#0B0F1A">GPT</text>
        </g>
        <!-- mistral -->
        <g transform="translate(0, 60)">
          <rect x="0" y="0" width="140" height="24" rx="6" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
          <text x="70" y="16" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="800" fill="#0B0F1A">mistral</text>
        </g>
        <!-- AlpineAI (highlight) -->
        <g transform="translate(-10, 90)">
          <rect x="0" y="0" width="160" height="26" rx="6" fill="#0B0F1A" stroke="#0B0F1A" stroke-width="2" />
          <text x="80" y="17" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="800" fill="#C9FF00">AlpineAI 🇨🇭</text>
        </g>
      </g>
    </g>

    <!-- Line 2: Center → Results -->
    <line x1="160" y1="304" x2="160" y2="344" stroke="#0B0F1A" stroke-width="2.5" stroke-dasharray="8 6" class="flow flow-2" />

    <!-- Results label -->
    <text x="160" y="340" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5" class="hidden-label"></text>

    <!-- Result 1: Zeit -->
    <g class="node node-output out-1">
      <rect x="30" y="344" width="260" height="52" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="48" y="368" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS 01
      </text>
      <text x="48" y="388" font-family="Inter, sans-serif" font-size="18" font-weight="800" fill="#0B0F1A">
        −58 % Zeit
      </text>
      <circle cx="266" cy="370" r="14" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="result-dot" />
      <text x="266" y="375" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="900" fill="#0B0F1A">↓</text>
    </g>

    <!-- Result 2: Aufträge -->
    <g class="node node-output out-2">
      <rect x="30" y="408" width="260" height="52" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="48" y="432" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS 02
      </text>
      <text x="48" y="452" font-family="Inter, sans-serif" font-size="18" font-weight="800" fill="#0B0F1A">
        +28 % Aufträge
      </text>
      <circle cx="266" cy="434" r="14" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="result-dot" />
      <text x="266" y="439" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="900" fill="#0B0F1A">↑</text>
    </g>

    <!-- Result 3: 24/7 -->
    <g class="node node-output out-3">
      <rect x="30" y="472" width="260" height="52" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="48" y="496" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS 03
      </text>
      <text x="48" y="516" font-family="Inter, sans-serif" font-size="18" font-weight="800" fill="#0B0F1A">
        24/7 läuft
      </text>
      <circle cx="266" cy="498" r="14" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="result-dot" />
      <text x="266" y="503" text-anchor="middle" font-family="Inter, sans-serif" font-size="14" font-weight="900" fill="#0B0F1A">✓</text>
    </g>

    <!-- Data packets flowing along the pipeline -->
    <circle r="7" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2.5">
      <animateMotion dur="1.6s" repeatCount="indefinite" path="M 160 66 L 160 104" />
    </circle>
    <circle r="7" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2.5">
      <animateMotion dur="1.6s" repeatCount="indefinite" begin="0.6s" path="M 160 304 L 160 344" />
    </circle>

    <!-- Swiss badge top-right -->
    <g class="swiss-badge">
      <circle cx="292" cy="30" r="20" fill="#0B0F1A" stroke="#0B0F1A" stroke-width="3" />
      <text x="292" y="35" text-anchor="middle" font-family="Inter, sans-serif" font-size="11">🇨🇭</text>
    </g>

    <!-- Live + status bottom -->
    <g>
      <circle cx="28" cy="540" r="5" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="live-dot" />
      <text x="42" y="544" font-family="Inter, sans-serif" font-size="11" font-weight="900" fill="#0B0F1A" letter-spacing="1">LIVE</text>
    </g>

    <g>
      <text x="90" y="544" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#6b7382">
        <tspan class="status-line status-1">Prozess analysiert ✓</tspan>
      </text>
      <text x="90" y="544" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#6b7382" opacity="0">
        <tspan class="status-line status-2">Lösung gebaut ✓</tspan>
      </text>
      <text x="90" y="544" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#6b7382" opacity="0">
        <tspan class="status-line status-3">Auf Swiss Cloud ✓</tspan>
      </text>
    </g>
  </svg>
</div>

<style>
  .hero-anim {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .flow {
    animation: dash-flow 1.4s linear infinite;
  }
  .flow-1 { animation-delay: 0s; }
  .flow-2 { animation-delay: 0.5s; }

  @keyframes dash-flow {
    to { stroke-dashoffset: -28; }
  }

  .ki-core {
    animation: ki-pulse 3s ease-in-out infinite;
  }

  @keyframes ki-pulse {
    0%, 100% {
      filter: drop-shadow(0 0 0px rgba(201, 255, 0, 0.5));
    }
    50% {
      filter: drop-shadow(0 0 14px rgba(201, 255, 0, 0.85));
    }
  }

  .node-output rect {
    animation: out-nudge 4s ease-in-out infinite;
  }
  .out-1 rect { animation-delay: 0.0s; }
  .out-2 rect { animation-delay: 0.5s; }
  .out-3 rect { animation-delay: 1.0s; }

  @keyframes out-nudge {
    0%, 100% { transform: translateX(0); }
    50% { transform: translateX(2px); }
  }

  .result-dot {
    animation: result-pulse 4s ease-in-out infinite;
    transform-origin: center;
  }
  .out-1 .result-dot { animation-delay: 0.0s; }
  .out-2 .result-dot { animation-delay: 0.5s; }
  .out-3 .result-dot { animation-delay: 1.0s; }

  @keyframes result-pulse {
    0%, 100% {
      opacity: 0.7;
    }
    50% {
      opacity: 1;
      filter: drop-shadow(0 0 6px rgba(201, 255, 0, 0.9));
    }
  }

  .live-dot {
    animation: live-pulse 1.2s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .status-line {
    animation: status-cycle 4.5s ease-in-out infinite;
    opacity: 0;
  }
  .status-1 { animation-delay: 0s; }
  .status-2 { animation-delay: 1.5s; }
  .status-3 { animation-delay: 3.0s; }

  @keyframes status-cycle {
    0%, 22% { opacity: 0; }
    5%, 20% { opacity: 1; }
    30%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow, .ki-core, .node-output rect, .result-dot, .live-dot, .status-line {
      animation: none;
    }
  }
</style>
