---
---

<div class="hero-anim" aria-hidden="true">
  <svg
    viewBox="0 0 500 460"
    class="w-full h-auto max-w-[480px]"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <filter id="lime-glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="6" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>

      <pattern id="bg-dots" x="0" y="0" width="26" height="26" patternUnits="userSpaceOnUse">
        <circle cx="2" cy="2" r="1" fill="#0B0F1A" opacity="0.12" />
      </pattern>
    </defs>

    <rect x="0" y="0" width="500" height="460" fill="url(#bg-dots)" />

    <!-- Top node: Ihr Prozess -->
    <g class="node node-input">
      <rect x="170" y="18" width="160" height="56" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="250" y="42" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        INPUT
      </text>
      <text x="250" y="62" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="800" fill="#0B0F1A">
        Ihr Prozess
      </text>
    </g>

    <!-- Line 1: Input → Center -->
    <line x1="250" y1="74" x2="250" y2="146" stroke="#0B0F1A" stroke-width="2.5" stroke-dasharray="8 6" class="flow flow-1" />

    <!-- Center node: KI AGENT with model badges -->
    <g class="node node-center">
      <rect x="90" y="146" width="320" height="130" rx="16" fill="#C9FF00" stroke="#0B0F1A" stroke-width="3" class="ki-core" />

      <text x="250" y="172" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#0B0F1A" letter-spacing="1.5">
        KI-AGENT
      </text>
      <text x="250" y="200" text-anchor="middle" font-family="Inter, sans-serif" font-size="22" font-weight="800" fill="#0B0F1A">
        Analyse · Bau · Betrieb
      </text>

      <!-- Model badges inside center -->
      <g transform="translate(114, 220)">
        <!-- claude -->
        <g>
          <rect x="0" y="0" width="58" height="24" rx="6" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
          <text x="29" y="16" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" font-weight="800" fill="#0B0F1A">claude</text>
        </g>
        <!-- gpt -->
        <g transform="translate(68, 0)">
          <rect x="0" y="0" width="44" height="24" rx="6" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
          <text x="22" y="16" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" font-weight="800" fill="#0B0F1A">GPT</text>
        </g>
        <!-- mistral -->
        <g transform="translate(122, 0)">
          <rect x="0" y="0" width="62" height="24" rx="6" fill="#ffffff" stroke="#0B0F1A" stroke-width="2" />
          <text x="31" y="16" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" font-weight="800" fill="#0B0F1A">mistral</text>
        </g>
        <!-- alpineai (highlighted dark bg) -->
        <g transform="translate(194, 0)">
          <rect x="0" y="0" width="78" height="24" rx="6" fill="#0B0F1A" stroke="#0B0F1A" stroke-width="2" />
          <text x="39" y="16" text-anchor="middle" font-family="Inter, sans-serif" font-size="10" font-weight="800" fill="#C9FF00">AlpineAI 🇨🇭</text>
        </g>
      </g>
    </g>

    <!-- Lines 2, 3, 4: Center → 3 outputs -->
    <line x1="180" y1="276" x2="100" y2="340" stroke="#0B0F1A" stroke-width="2.5" stroke-dasharray="8 6" class="flow flow-2" />
    <line x1="250" y1="276" x2="250" y2="340" stroke="#0B0F1A" stroke-width="2.5" stroke-dasharray="8 6" class="flow flow-3" />
    <line x1="320" y1="276" x2="400" y2="340" stroke="#0B0F1A" stroke-width="2.5" stroke-dasharray="8 6" class="flow flow-4" />

    <!-- Output 1: Zeit -->
    <g class="node node-output out-1">
      <rect x="20" y="340" width="160" height="56" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="100" y="364" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS
      </text>
      <text x="100" y="384" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="800" fill="#0B0F1A">
        −58 % Zeit
      </text>
    </g>

    <!-- Output 2: Aufträge -->
    <g class="node node-output out-2">
      <rect x="170" y="340" width="160" height="56" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="250" y="364" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS
      </text>
      <text x="250" y="384" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="800" fill="#0B0F1A">
        +28 % Aufträge
      </text>
    </g>

    <!-- Output 3: Umsatz -->
    <g class="node node-output out-3">
      <rect x="320" y="340" width="160" height="56" rx="12" fill="#ffffff" stroke="#0B0F1A" stroke-width="3" />
      <text x="400" y="364" text-anchor="middle" font-family="Inter, sans-serif" font-size="9" font-weight="900" fill="#6b7382" letter-spacing="1.5">
        ERGEBNIS
      </text>
      <text x="400" y="384" text-anchor="middle" font-family="Inter, sans-serif" font-size="16" font-weight="800" fill="#0B0F1A">
        24/7 läuft
      </text>
    </g>

    <!-- Moving data packets -->
    <circle r="7" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2.5">
      <animateMotion dur="1.6s" repeatCount="indefinite" path="M 250 74 L 250 146" />
    </circle>
    <circle r="7" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2.5">
      <animateMotion dur="1.8s" repeatCount="indefinite" begin="0.4s" path="M 180 276 L 100 340" />
    </circle>
    <circle r="7" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2.5">
      <animateMotion dur="1.8s" repeatCount="indefinite" begin="0.7s" path="M 250 276 L 250 340" />
    </circle>
    <circle r="7" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2.5">
      <animateMotion dur="1.8s" repeatCount="indefinite" begin="1.0s" path="M 320 276 L 400 340" />
    </circle>

    <!-- Swiss badge top-right -->
    <g class="swiss-badge">
      <circle cx="462" cy="34" r="22" fill="#0B0F1A" stroke="#0B0F1A" stroke-width="3" />
      <text x="462" y="39" text-anchor="middle" font-family="Inter, sans-serif" font-size="12">🇨🇭</text>
    </g>

    <!-- Live + cycling status at bottom -->
    <g>
      <circle cx="28" cy="432" r="5" fill="#C9FF00" stroke="#0B0F1A" stroke-width="2" class="live-dot" />
      <text x="42" y="436" font-family="Inter, sans-serif" font-size="11" font-weight="900" fill="#0B0F1A" letter-spacing="1">LIVE</text>
    </g>

    <g>
      <text x="90" y="436" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#6b7382">
        <tspan class="status-line status-1">Prozess analysiert ✓</tspan>
      </text>
      <text x="90" y="436" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#6b7382" opacity="0">
        <tspan class="status-line status-2">Lösung gebaut ✓</tspan>
      </text>
      <text x="90" y="436" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#6b7382" opacity="0">
        <tspan class="status-line status-3">Auf Swiss Cloud deployed ✓</tspan>
      </text>
    </g>
  </svg>
</div>

<style>
  .hero-anim {
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .flow {
    animation: dash-flow 1.4s linear infinite;
  }
  .flow-1 { animation-delay: 0s; }
  .flow-2 { animation-delay: 0.3s; }
  .flow-3 { animation-delay: 0.5s; }
  .flow-4 { animation-delay: 0.7s; }

  @keyframes dash-flow {
    to { stroke-dashoffset: -28; }
  }

  .ki-core {
    animation: ki-pulse 3s ease-in-out infinite;
  }

  @keyframes ki-pulse {
    0%, 100% {
      filter: drop-shadow(0 0 0px rgba(201, 255, 0, 0.5));
    }
    50% {
      filter: drop-shadow(0 0 14px rgba(201, 255, 0, 0.85));
    }
  }

  .node-output rect {
    animation: out-nudge 4s ease-in-out infinite;
  }
  .out-1 rect { animation-delay: 0.0s; }
  .out-2 rect { animation-delay: 0.4s; }
  .out-3 rect { animation-delay: 0.8s; }

  @keyframes out-nudge {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
  }

  .live-dot {
    animation: live-pulse 1.2s ease-in-out infinite;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .status-line {
    animation: status-cycle 4.5s ease-in-out infinite;
    opacity: 0;
  }
  .status-1 { animation-delay: 0s; }
  .status-2 { animation-delay: 1.5s; }
  .status-3 { animation-delay: 3.0s; }

  @keyframes status-cycle {
    0%, 22% { opacity: 0; }
    5%, 20% { opacity: 1; }
    30%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow, .ki-core, .node-output rect, .live-dot, .status-line {
      animation: none;
    }
  }
</style>
