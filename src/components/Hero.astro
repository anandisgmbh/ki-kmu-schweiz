---
import HeroAnimation from './HeroAnimation.astro';

const calendlyUrl = import.meta.env.PUBLIC_CALENDLY_URL || 'https://calendly.com/hello-ki-kmu-schweiz/30min';
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '';
const whatsappText = encodeURIComponent(
  'Hallo Jannick, ich interessiere mich für ein Erstgespräch zur KI-Beratung.'
);
const whatsappUrl = whatsappNumber
  ? `https://wa.me/${whatsappNumber}?text=${whatsappText}`
  : '#kontakt';
---

<section class="relative overflow-hidden pt-16 md:pt-24 pb-20 md:pb-28">
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 opacity-[0.04]"
    style="background-image: linear-gradient(#0B0F1A 1px, transparent 1px), linear-gradient(90deg, #0B0F1A 1px, transparent 1px); background-size: 48px 48px;"
  ></div>

  <div class="container-page">
    <div class="grid lg:grid-cols-[minmax(0,1fr)_260px] gap-10 lg:gap-10 items-center">
      <div class="min-w-0">
        <div class="flex items-center gap-3 mb-7">
          <span class="label-tag bg-ink-primary text-accent px-3 py-1.5 rounded-full">
            KI für Schweizer KMU
          </span>
          <span class="label-tag text-ink-muted">
            Prozess → Pilot → Betrieb
          </span>
        </div>

        <h1 class="text-mega text-ink-primary">
          KI, die in 8 Wochen<br />
          <span class="mark-accent">wirklich läuft</span>.<br />
          Nicht in PowerPoint.
        </h1>

        <p class="mt-8 text-lg md:text-xl leading-relaxed text-ink-secondary max-w-[640px]">
          Ich bin Ihr persönlicher KI-Partner für messbare Prozess-Automatisierung.
          Kein Workshop-Zirkus, keine Enterprise-Rechnung, keine Ausreden.
          <span class="font-semibold text-ink-primary">Ein Mensch vorne, ein kuratiertes Netzwerk dahinter</span>,
          und am Ende steht eine Lösung, die Ihr Team bedienen kann — ohne Doktortitel.
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          <a href={calendlyUrl} class="btn-primary text-base w-full sm:w-auto">
            Erstgespräch buchen
            <span aria-hidden="true">→</span>
          </a>
          <a href="#angebot" class="btn-ghost text-base flex-1 sm:flex-none min-w-0">Pakete &amp; Fixpreise</a>
          <a
            href={whatsappUrl}
            class="btn-whatsapp text-base flex-1 sm:flex-none min-w-0"
            aria-label="Per WhatsApp schreiben"
            target="_blank"
            rel="noopener"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            WhatsApp
          </a>
        </div>

        <div class="mt-14 flex items-center gap-5 pt-8 border-t-2 border-ink-primary max-w-[560px]">
          <img
            src="/images/jannick-portrait.jpg"
            alt="Jannick Oberbeck"
            width="56"
            height="56"
            loading="eager"
            class="w-14 h-14 shrink-0 rounded-full object-cover border-2 border-ink-primary"
          />
          <div class="text-sm leading-tight">
            <p class="font-extrabold text-ink-primary text-base">Jannick Oberbeck</p>
            <p class="text-ink-muted">MSc Maschinenbau · ETH Zürich · 5+ Jahre KI-Praxis · 10+ gelieferte Projekte</p>
          </div>
        </div>
      </div>

      <div class="hidden lg:block">
        <HeroAnimation />
      </div>
    </div>
  </div>
</section>
