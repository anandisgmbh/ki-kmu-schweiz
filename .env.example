# Resend API key (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Contact form destination email (where form submissions land)
CONTACT_FORM_TO=info@anandis.ch

# Optional: Resend from address (must be from a verified domain in Resend)
# Defaults to "KI-KMU-Schweiz <noreply@mietkosten.ch>" if unset
RESEND_FROM=KI-KMU-Schweiz <noreply@mietkosten.ch>

# Calendly booking URL
PUBLIC_CALENDLY_URL=https://calendly.com/hello-ki-kmu-schweiz/30min

# WhatsApp number (international format, digits only)
PUBLIC_WHATSAPP_NUMBER=4179XXXXXXX

# Contact email (visible on page)
PUBLIC_CONTACT_EMAIL=hello@ki-kmu-schweiz.ch

# Contact phone (visible on page)
PUBLIC_CONTACT_PHONE=+41 78 442 88 88

# Anthropic API key for KI-Bedarfsanalyse chatbot
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx
